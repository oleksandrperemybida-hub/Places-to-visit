<Window x:Class="PlacesToVisit.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PlacesToVisit"
        mc:Ignorable="d"
        Title="Miejsca warte odwiedzenia" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Margin="20">
                <TextBlock Text="✈️ My travels" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           Margin="0,0,0,40" 
                           HorizontalAlignment="Center"/>

                <Button Content="🌍 All places" Click="AllPlaces_Click" 
                        Height="45" 
                        Margin="0,0,0,15" 
                        FontSize="16" 
                        Background="#34495E" 
                        Foreground="White" 
                        BorderThickness="0"
                        Cursor="Hand"/>
                <Button Content="All places" Click="NavAll_Click" Margin="0,0,0,0" Foreground="AliceBlue" Background="#34495E"/>
                <Button Content="Visited" Click="NavVisited_Click" Margin="0,5,0,0" Foreground="AliceBlue" Background="#34495E"/>
                <Button Content="Wishlist" Click="NavWish_Click" Margin="0,5,0,0" Foreground="AliceBlue" Background="#34495E"/>
                <Button Content="Saved" Click="NavSaved_Click" Margin="0,5,0,15" Foreground="AliceBlue" Background="#34495E"/>

                <Button Content="Add place" Click="AddPlaces_Click" 
                        Height="45" 
                        Margin="0,0,0,15" 
                        FontSize="16" 
                        Background="#34495E" 
                        Foreground="White" 
                        BorderThickness="0"
                        Cursor="Hand"/>

                <Button Content="⚙️ Properties" 
                        Height="45" 
                        FontSize="16" 
                        Background="#34495E" 
                        Foreground="White" 
                        BorderThickness="0"
                        Cursor="Hand"/>
                
            </StackPanel>
        </Border>
        

        <Border Grid.Column="1" Background="#F5F6FA">

            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Margin="10"/>
        </Border>

    </Grid>
</Window>