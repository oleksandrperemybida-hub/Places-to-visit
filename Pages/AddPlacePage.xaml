<Page x:Class="PlacesToVisit.Pages.AddPlacePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AddPlacePage">

    <Grid Margin="30">
        <StackPanel MaxWidth="500" HorizontalAlignment="Left">

            <TextBlock Text="Add new place" FontSize="28" FontWeight="Bold" Margin="0,0,0,30" Foreground="#2C3E50"/>

            <TextBlock Text="New place name" Margin="0,10,0,5" Foreground="#7F8C8D" FontSize="14"/>
            <TextBox x:Name="NameInput" Height="40" VerticalContentAlignment="Center" Padding="10,0" FontSize="16" BorderBrush="#BDC3C7" BorderThickness="1"/>

            <TextBlock Text="Description" Margin="0,20,0,5" Foreground="#7F8C8D" FontSize="14"/>
            <TextBox x:Name="DescriptionInput" Height="120" TextWrapping="Wrap" AcceptsReturn="True" Padding="10" FontSize="16" BorderBrush="#BDC3C7" BorderThickness="1"/>

            <TextBlock Text="Image" Margin="0,20,0,5" Foreground="#7F8C8D" FontSize="14"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="ImageInput" Height="40" VerticalContentAlignment="Center" Padding="10,0" FontSize="16" BorderBrush="#BDC3C7" BorderThickness="1" IsReadOnly="True" Background="#F8F9FA"/>

                <Button Grid.Column="1" Content="📂 Browse" Width="100" Margin="10,0,0,0" Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="SelectImage_Click"/>
            </Grid>

            <Button x:Name="SaveButton" Content="Save place" Click="SavePlace_Click"
                    Margin="0,40,0,0" 
                    Height="50" 
                    Background="#27AE60" 
                    Foreground="White" 
                    FontSize="18"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"/>

        </StackPanel>
    </Grid>
</Page>