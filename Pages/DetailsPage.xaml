<Page x:Class="PlacesToVisit.Pages.DetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="DetailsPage" Background="#F8F9FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50">
            <Button Content="⬅ Back to list" 
                    Click="Back_Click"
                    HorizontalAlignment="Left" 
                    Margin="20,0,0,0" 
                    Background="Transparent" 
                    Foreground="White" 
                    FontSize="16" 
                    FontWeight="SemiBold" 
                    BorderThickness="0" 
                    Cursor="Hand"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,30,0,50">

            <StackPanel HorizontalAlignment="Center" MaxWidth="850" Margin="20,0">

                <Border CornerRadius="12" 
                        ClipToBounds="True" 
                        Margin="0,0,0,30" 
                        MaxHeight="450" 
                        HorizontalAlignment="Center">
                    <Image Source="{Binding ImageUrl}" 
                           Stretch="Uniform" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>
                </Border>

                <StackPanel Margin="10,0">

                    <TextBlock Text="{Binding Name}" 
                               FontSize="42" 
                               FontWeight="Bold" 
                               Foreground="#2C3E50" 
                               TextWrapping="Wrap" 
                               HorizontalAlignment="Left"
                               Margin="0,0,0,10"/>

                    <Rectangle Height="4" 
                               Width="60" 
                               Fill="#3498DB" 
                               HorizontalAlignment="Left" 
                               Margin="0,0,0,25" 
                               RadiusX="2" 
                               RadiusY="2"/>

                    <TextBlock Text="{Binding Opis}" 
                               FontSize="18" 
                               Foreground="#4F5D75" 
                               TextWrapping="Wrap" 
                               LineHeight="28" 
                               HorizontalAlignment="Left"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>