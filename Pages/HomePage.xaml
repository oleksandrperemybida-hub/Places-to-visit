<Page x:Class="PlacesToVisit.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="HomePage"
      Background="Transparent">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="PageTitle" Text="All places" FontSize="28" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>

            <Border Grid.Column="1" Background="White" CornerRadius="5" BorderBrush="#E0E0E0" BorderThickness="1" Height="35">
                <TextBox x:Name="SearchBox" 
                         VerticalAlignment="Center" 
                         Margin="10,0" 
                         BorderThickness="0" 
                         FontSize="14" 
                         Foreground="#7F8C8D" TextChanged="SearchBox_TextChanged"/>
            </Border>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

            <ItemsControl x:Name="PlacesList">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" Width="280" Height="280" Margin="0,0,20,20" CornerRadius="10" MouseLeftButtonUp="PlaceClick_Card">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1" Direction="270"/>
                            </Border.Effect>
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="✅ Mark as visited" Click="MarkVisited_Click"/>
                                    <MenuItem Header="⭐ Add to wishes" Click="AddWish_Click" />
                                    <Separator />
                                    <MenuItem Header="🗑️ Delete place" Foreground="Red" Click="DeletePlace_MenuItem_Click"/>
                                </ContextMenu>
                            </Border.ContextMenu>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="160"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border CornerRadius="10,10,0,0" ClipToBounds="True">
                                    <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                </Border>
                                <Border HorizontalAlignment="Right" 
                                    VerticalAlignment="Top" 
                                    Margin="10" 
                                    CornerRadius="5" 
                                    Padding="8,4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#95A5A6"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Visited">
                                                    <Setter Property="Background" Value="#27AE60"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Wish">
                                                    <Setter Property="Background" Value="Red"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <TextBlock Text="{Binding Status}" 
                                       Foreground="White" 
                                       FontWeight="Bold" 
                                       FontSize="12"/>
                                </Border>

                                <StackPanel Grid.Row="1" Margin="15">
                                    <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Opis}" FontSize="13" Foreground="#7F8C8D" Margin="0,5,0,0" TextWrapping="Wrap" MaxHeight="40" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </ScrollViewer>
    </Grid>
</Page>